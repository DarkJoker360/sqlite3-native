{
  "name": "sqlite3-native",
  "version": "0.1.0",
  "description": "Asynchronous SQLite3 bindings for JavaScript with VFS support",
  "exports": {
    "./package": "./package.json",
    ".": "./index.js",
    "./constants": "./lib/constants.js"
  },
  "files": [
    "index.js",
    "binding.c",
    "binding.js",
    "CMakeLists.txt",
    "lib",
    "prebuilds"
  ],
  "addon": true,
  "scripts": {
    "format": "prettier --write . && lunte --fix",
    "lint": "prettier --check . && lunte",
    "test": "npm run test:bare && npm run test:node",
    "test:bare": "brittle-bare --coverage test.js",
    "test:node": "brittle-node --coverage test.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/holepunchto/sqlite3-native.git"
  },
  "author": "Holepunch",
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/holepunchto/sqlite3-native/issues"
  },
  "homepage": "https://github.com/holepunchto/sqlite3-native#readme",
  "engines": {
    "bare": ">=1.4.0"
  },
  "dependencies": {
    "ready-resource": "^1.0.3",
    "require-addon": "^1.0.2"
  },
  "devDependencies": {
    "bare-compat-napi": "^1.0.0",
    "brittle": "^3.4.0",
    "cmake-bare": "^1.1.15",
    "cmake-fetch": "^1.2.0",
    "cmake-napi": "^1.0.7",
    "cmake-npm": "^1.0.2",
    "lunte": "^1.8.0",
    "prettier": "^3.4.2",
    "prettier-config-holepunch": "^2.0.0"
  }
}
